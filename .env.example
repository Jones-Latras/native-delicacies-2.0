# Database (Supabase PostgreSQL)
# Runtime on Vercel / serverless: Supavisor transaction mode, port 6543.
# Add pgbouncer=true because transaction mode does not support prepared statements.
DATABASE_URL="postgresql://prisma.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Prisma CLI / migrations / seeds: direct connection or Supavisor session mode, port 5432.
# Use the direct URL if your environment supports IPv6; otherwise use the session pooler URL.
DIRECT_URL="postgresql://prisma.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Auth
NEXTAUTH_SECRET="your-nextauth-secret-change-this"
NEXTAUTH_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Xendit
XENDIT_SECRET_KEY="xnd_development_..."
XENDIT_WEBHOOK_TOKEN="xnd_webhook_token_..."

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM_NAME="J&J Native Delicacies"
EMAIL_FROM_ADDRESS="noreply@yourdomain.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
